---
import '@/styles/global.css';
import { Sparkles, ArrowUpRight } from 'lucide-react';
import { LoginForm } from '@/features/auth/login-form';

const TICKER_WORDS = ['THINK', 'CREATE', 'BUILD', 'SHIP', 'REPEAT'];
const tickerItems = [...TICKER_WORDS, ...TICKER_WORDS];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Log in — jimly.ai</title>
  </head>
  <body>
    <main
      class="relative flex h-screen w-screen flex-col overflow-y-auto md:flex-row md:overflow-y-hidden"
      style="--auth-ink: #102A43; --auth-accent: #C49A45;"
    >
      <div class="h-auto w-full shrink-0 py-12 md:h-full md:w-1/2 md:py-0">
        <div class="relative flex h-full w-full flex-col justify-between overflow-hidden bg-(--auth-ink) px-8 py-10 text-white sm:px-12 sm:py-14">
          <div
            class="pointer-events-none absolute inset-0 opacity-[0.18] mix-blend-overlay"
            style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 14px 14px;"
          >
          </div>
          <div class="pointer-events-none absolute -top-32 -right-20 size-80 rounded-full bg-(--auth-accent) opacity-20 blur-[100px]"></div>
          <div class="pointer-events-none absolute -bottom-24 -left-16 size-72 rounded-full bg-(--auth-accent) opacity-10 blur-[100px]"></div>

          <div class="relative z-10 flex items-center justify-between">
            <span class="font-sans text-sm font-semibold tracking-tight">jimly.ai</span>
          </div>

          <div class="relative z-10 max-w-md">
            <h2 class="text-[2.75rem] leading-[1.05] font-semibold tracking-tight sm:text-5xl">
              Good to see you again.
            </h2>
            <p class="mt-5 text-sm leading-relaxed text-white/55 sm:text-base">
              Sign in and pick the thread back up — your workspace is exactly how you left it.
            </p>
            <a
              href="/register"
              class="group mt-8 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/5 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:border-(--auth-accent) hover:bg-(--auth-accent) hover:text-(--auth-ink)"
            >
              Create account instead
              <ArrowUpRight className="size-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
            </a>
          </div>

          <div class="relative z-10 hidden sm:block">
            <div class="relative flex w-full overflow-hidden border-y border-white/10 py-2.5">
              <div class="flex w-max shrink-0 animate-marquee gap-6 pr-6">
                {tickerItems.map((word, i) => (
                  <span class="flex items-center gap-6 text-xs font-medium tracking-[0.3em] text-white/40">
                    {word}
                    <Sparkles className="size-3 text-(--auth-accent)" />
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="flex-1 md:w-1/2">
        <div class="flex h-full w-full flex-col justify-center bg-background px-8 py-14 sm:px-14">
          <div class="mx-auto w-full max-w-sm">
            <div class="mb-8 flex gap-1 rounded-full bg-muted p-1">
              <span class="flex-1 rounded-full bg-background py-2 text-center text-sm font-medium text-foreground shadow-sm">
                Log in
              </span>
              <a
                href="/register"
                class="flex-1 rounded-full py-2 text-center text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
              >
                Sign up
              </a>
            </div>

            <div>
              <h1 class="text-2xl font-semibold tracking-tight text-foreground">Welcome back</h1>
              <p class="mt-1.5 text-sm text-muted-foreground">Pick up right where you left off.</p>

              <div class="mt-7">
                <LoginForm client:load />
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
