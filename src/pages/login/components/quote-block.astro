---
import { Quote } from 'lucide-react';
---

<div class="relative z-10 hidden sm:block max-w-lg border-l-2 border-(--auth-accent)/40 pl-4 py-1">
  <Quote className="size-5 text-(--auth-accent) opacity-60 mb-2" />
  <p class="text-xs italic font-light tracking-wide text-white/70 leading-relaxed">
    "Konstitusi bukan sekadar dokumen hukum mati, melainkan kesepakatan luhur yang hidup dan menuntun keadilan sebuah bangsa."
  </p>
  <span class="block mt-2 text-[10px] uppercase tracking-widest text-white/40 font-medium">
    — Filosofi Hukum Tata Negara
  </span>
</div>