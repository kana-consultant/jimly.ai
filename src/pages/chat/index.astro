---
import '@/styles/global.css';
import { ChatSidebar } from '@/features/chat/components/sidebar';
import { MobileSidebarOverlay } from '@/features/chat/components/mobile-sidebar-overlay';
import { ChatHeader } from '@/features/chat/components/chat-header';
import { ChatThread } from '@/features/chat/components/chat-thread';
import { AuthHydrator } from '@/features/chat/components/auth-hydrator';

const { userId, email, name } = Astro.locals;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Chat — jimly.ai</title>
  </head>
  <body>
    <AuthHydrator id={userId} email={email} name={name} client:load />
    <div class="flex h-screen flex-col">
      <div class="flex flex-1 overflow-hidden">
        <div class="hidden md:flex">
          <ChatSidebar client:load />
        </div>

        <MobileSidebarOverlay client:load />

        <div class="flex flex-1 flex-col relative">
          <ChatHeader client:load />
          <ChatThread client:load />
        </div>
      </div>
    </div>
  </body>
</html>
