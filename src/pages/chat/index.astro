---
import '@/styles/global.css';
import { ChatSidebar } from '@/pages/chat/components/chat-sidebar';
import { ChatThread } from '@/pages/chat/components/chat-thread';
import { ChatInput } from '@/pages/chat/components/chat-input';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Chat — jimly.ai</title>
  </head>
  <body>
    <main class="flex h-screen">
      <ChatSidebar client:load />
      <div class="flex flex-1 flex-col">
        <div class="flex-1 overflow-y-auto">
          <ChatThread client:load />
        </div>
        <ChatInput client:load />
      </div>
    </main>
  </body>
</html>
