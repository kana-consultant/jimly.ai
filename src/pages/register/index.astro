---
import '@/styles/global.css';
import LeftPanel from './components/left-panel.astro';
import RightPanel from './components/right-panel.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Sign up — jimly.ai</title>
  </head>
  <body>
    <main
      class="relative flex h-screen w-screen flex-col overflow-y-auto md:flex-row md:overflow-y-hidden"
      style="--auth-ink: #102A43; --auth-accent: #C49A45;"
    >
      <LeftPanel />
      <RightPanel />
    </main>
  </body>
</html>