{
  "framework": "other",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm --filter @jimly/api build && node apps/api/scripts/ensure-public-dir.mjs",
  "outputDirectory": "public",
  "builds": [
    { "src": "routes/**/*.ts", "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/api/auth/:path*", "destination": "/routes/auth/handler" },
    { "source": "/api/sessions/:id/messages", "destination": "/routes/sessions/:id/messages" },
    { "source": "/api/sessions/:id", "destination": "/routes/sessions/:id" },
    { "source": "/api/sessions", "destination": "/routes/sessions/index" },
    { "source": "/api/chat", "destination": "/routes/chat" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
