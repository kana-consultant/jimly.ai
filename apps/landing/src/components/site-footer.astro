---
const EXPLORE_LINKS = [
  { href: "#features", label: "Features" },
  { href: "#how", label: "How it works" },
  { href: "#books", label: "Books" },
]

const LEGAL_LINKS = [
  { href: "#", label: "Privacy" },
  { href: "#", label: "Terms" },
  { href: "#", label: "Contact" },
]
---

<footer class="bg-primary px-10 pb-8 pt-16 text-primary-foreground sm:pt-20">
  <div class="mx-auto flex max-w-5xl flex-col gap-10 sm:flex-row sm:justify-between">
    <div class="max-w-xs">
      <div class="font-display text-xl font-semibold">
        jimly<span class="text-chart-5">.ai</span>
      </div>
      <p class="mt-3 text-[13px] leading-relaxed text-primary-foreground/70">
        AI legal assistant built on the scholarship of Prof. Dr. H. Jimly Asshiddiqie.
      </p>
    </div>
    <div class="flex gap-12">
      <div>
        <div class="text-[12px] font-medium uppercase tracking-wide text-chart-5">Explore</div>
        <ul class="mt-3 flex flex-col gap-2.5">
          {EXPLORE_LINKS.map((link) => (
            <li>
              <a href={link.href} class="text-[13.5px] text-primary-foreground/70 transition-colors hover:text-primary-foreground">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <div class="text-[12px] font-medium uppercase tracking-wide text-chart-5">Legal</div>
        <ul class="mt-3 flex flex-col gap-2.5">
          {LEGAL_LINKS.map((link) => (
            <li>
              <a href={link.href} class="text-[13.5px] text-primary-foreground/70 transition-colors hover:text-primary-foreground">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
  <div class="mx-auto mt-12 max-w-5xl border-t border-primary-foreground/10 pt-5 text-center text-xs text-primary-foreground/50 sm:text-left">
    © 2025 jimly.ai · All rights reserved.
  </div>
</footer>
