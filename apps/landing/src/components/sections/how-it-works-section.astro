---
import { CheckCircle2, MessageSquare, Library } from "lucide-react"

const STEPS = [
  {
    icon: MessageSquare,
    num: "STEP 01",
    title: "Ask your question",
    desc: "Type any question about Indonesian law, constitutional rights, or state administration — in Bahasa Indonesia or English.",
  },
  {
    icon: Library,
    num: "STEP 02",
    title: "AI searches the library",
    desc: "jimly.ai scans 70+ books and hundreds of academic papers to find the most relevant passages from Prof. Jimly's body of work.",
  },
  {
    icon: CheckCircle2,
    num: "STEP 03",
    title: "Get a sourced answer",
    desc: "Receive a precise answer with the exact book title and chapter cited — so you always know where the knowledge comes from.",
  },
]
---

<section class="bg-card shadow-sm" id="how">
  <div class="mx-auto max-w-275 px-10 py-22">
    <div class="mb-14">
      <h2 class="font-sans text-[clamp(34px,3.5vw,48px)] leading-tight font-semibold tracking-tight text-primary">
        From question to <em class="font-normal text-chart-5 italic">cited answer</em>
      </h2>
      <p class="mt-3 max-w-125 text-[15px] leading-relaxed text-muted-foreground">
        Every response is grounded in Prof. Jimly's published works — not generic AI training data.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      {STEPS.map((step) => (
        <div class="group rounded-2xl bg-background p-9 px-8 shadow-sm transition-[transform,box-shadow] duration-500 hover:-translate-y-1 hover:shadow-lg hover:shadow-primary/10">
          <div class="mb-4 font-display text-[13px] font-semibold tracking-widest text-chart-5">
            {step.num}
          </div>
          <div class="mb-5 flex size-11 items-center justify-center rounded-xl bg-primary transition-transform duration-300 group-hover:scale-110">
            <step.icon className="size-5 text-primary-foreground" strokeWidth={1.75} />
          </div>
          <div class="mb-2 text-base font-semibold text-primary">{step.title}</div>
          <p class="text-[13.5px] leading-relaxed text-muted-foreground">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
