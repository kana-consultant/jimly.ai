---
import { Landmark, Network, ShieldCheck, Users } from "lucide-react"

const FEATURES = [
  {
    icon: Landmark,
    name: "Constitutional Law",
    desc: "Interpret the 1945 Constitution, judicial review of legislation, and the authority of state institutions.",
  },
  {
    icon: Network,
    name: "State Administration",
    desc: "Navigate government institutions, bureaucratic structure, state authority, and the rule of law in democratic Indonesia.",
  },
  {
    icon: ShieldCheck,
    name: "Legal Ethics & Judiciary",
    desc: "Understand the ethics of legal institutions, judicial conduct, and the moral foundations of Indonesian law.",
  },
  {
    icon: Users,
    name: "Human Rights & Democracy",
    desc: "Explore constitutional rights, democratic reform, civil liberties, and Indonesia's post-Reformasi transition.",
  },
]
---

<section class="mx-auto max-w-275 px-10 py-22" id="features">
  <div class="mb-12">
    <h2 class="font-sans text-[clamp(34px,3.5vw,48px)] leading-tight font-semibold tracking-tight text-primary">
      Every question answered
      <br />
      from <em class="font-normal text-chart-5 italic">the source</em>
    </h2>
    <p class="mt-3 max-w-125 text-[15px] leading-relaxed text-muted-foreground">
      jimly.ai cites exact books and chapters with every answer — not generic AI outputs.
    </p>
  </div>
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {FEATURES.map((feature) => (
      <div class="group rounded-2xl bg-card p-7 shadow-sm transition-[transform,box-shadow] duration-500 hover:-translate-y-1 hover:shadow-lg hover:shadow-primary/10">
        <div class="mb-5 flex size-10 items-center justify-center rounded-xl bg-primary transition-transform duration-300 group-hover:scale-110">
          <feature.icon className="size-4.5 text-primary-foreground" strokeWidth={1.75} />
        </div>
        <div class="mb-2 text-[15px] font-semibold text-primary">{feature.name}</div>
        <p class="text-[13px] leading-relaxed text-muted-foreground">{feature.desc}</p>
      </div>
    ))}
  </div>
</section>
